# YouTube Data API v3 key
# https://console.cloud.google.com/ 에서 발급
YOUTUBE_API_KEY=your_youtube_api_key_here

# Groq API key (무료) - https://console.groq.com/ 에서 발급
GROQ_API_KEY=your_groq_api_key_here

# 분석할 유튜브 채널 (@핸들 또는 UC로 시작하는 채널 ID 모두 가능)
CHANNEL_ID=@hk_koreamarket

# 수집 기간 (일수, 기본 365일 = 1년)
DAYS_TO_FETCH=365
